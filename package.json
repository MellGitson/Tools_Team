{
  "name": "chatbot-cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Multi-provider CLI chatbot with memory, streaming, and history",
  "main": "src/chatbot-cli.js",
  "scripts": {
    "start": "node src/chatbot-cli.js",
    "dev": "node --watch src/chatbot-cli.js",
    "api": "node src/api.js",
    "api:dev": "node --watch src/api.js",
    "calculator": "node src/calculatrice-agent.js",
    "calculator:dev": "node --watch src/calculatrice-agent.js",
    "weather": "node src/weather-agent.js",
    "weather:dev": "node --watch src/weather-agent.js",
    "weather:pdf": "node src/weather-pdf-agent.js",
    "weather:pdf:dev": "node --watch src/weather-pdf-agent.js",
    "weather:display": "node src/weather-display-agent.js",
    "weather:display:dev": "node --watch src/weather-display-agent.js",
    "search": "node src/search-agent.js",
    "search:dev": "node --watch src/search-agent.js",
    "multi-tool": "node src/multi-tool-agent.js",
    "multi-tool:dev": "node --watch src/multi-tool-agent.js",
    "conversation": "node src/conversation-agent.js",
    "conversation:dev": "node --watch src/conversation-agent.js",
    "pinecone": "node src/pinecone-agent.js",
    "pinecone:dev": "node --watch src/pinecone-agent.js",
    "embedding": "node src/embedding-agent.js",
    "embedding:dev": "node --watch src/embedding-agent.js",
    "embedding:test": "node src/embedding-test.js",
    "embedding:test:dev": "node --watch src/embedding-test.js",
    "embedding:multi": "node src/embedding-multi-provider.js",
    "embedding:multi:dev": "node --watch src/embedding-multi-provider.js",
    "embedding:providers:test": "node src/embedding-providers-test.js",
    "embedding:pinecone:verify": "node src/embedding-pinecone-verify.js",
    "rag:audit": "node src/rag-audit.js",
    "rag:query": "node src/rag-query-agent.js",
    "rag:full": "node src/rag-generator.js",
    "hybrid": "node src/hybrid-agent.js"
  },
  "keywords": [
    "chatbot",
    "cli",
    "mistral",
    "groq",
    "huggingface",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pdfkit": "^0.18.0"
  }
}
